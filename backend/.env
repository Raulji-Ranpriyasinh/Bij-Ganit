# Copy to .env and adjust. Never commit .env.
APP_ENV=development
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Async URL used by the FastAPI app.
DATABASE_URL=postgresql+asyncpg://bijganit:bijganit@localhost:5432/bijganit
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg2://bijganit:bijganit@localhost:5432/bijganit

REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed CORS origins (frontend dev URL etc.).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
